# Автоматический вызов сценария по умолчанию (цель all)
$ make
gcc -Wall -Wextra -std=c11 -c main.c
gcc -Wall -Wextra -std=c11 -c calc.c
gcc main.o calc.o -o app

# Запуск скомпилированного бинарного приложения
$ ./app
Многофайловый проект. Результат: 20

# Вызов кастомной цели очистки рабочего каталога
$ make clean
rm -rf *.o app
